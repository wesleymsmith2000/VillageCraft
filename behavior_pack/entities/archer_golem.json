        "tame_event": "custom:on_tamed"
      },
      "minecraft:is_baby": false,
      "minecraft:on_death": {}
    },
    "events": {
      "custom:on_tamed": {
        "add": {
          "component_groups": ["tamed"]
        },
        "run_command": {
          "command": "title @s title Archer Golem Tamed!"
        }
      },
      "minecraft:entity_spawned": {
        "add": {
          "component_groups": ["wild"]
        }
      }
    },
    "component_groups": {
      "wild": {
        "minecraft:behavior.melee_attack": {
          "speed_multiplier": 0.5,
          "track_target": true,
          "require_complete_path": false
        },
        "minecraft:behavior.hurt_by_react": {
          "alert_others": true
        }
      },
      "tamed": {
        "minecraft:behavior.follow_owner": {
          "speed_multiplier": 1.0,
          "start_distance": 10,
          "stop_distance": 2
        },
        "minecraft:owners": []
      }
    }
