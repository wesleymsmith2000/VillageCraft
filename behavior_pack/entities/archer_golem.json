        "speed_multiplier": 1.0,
        "fail_radius": 50
      },
      "minecraft:behavior.panic": {
        "speed_multiplier": 0.66
      },
      "minecraft:behavior.random_stroll": {
        "speed_multiplier": 0.4,
        "xz_dist": 10,
        "y_dist": 7
      },
      "minecraft:loot": {
        "table": "loot_tables/entities/archer_golem.json"
      },
      "minecraft:experience_reward": {
